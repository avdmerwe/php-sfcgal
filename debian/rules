#!/usr/bin/make -f
# -*- makefile -*-
# SPDX-License-Identifier: LGPL-2.0-or-later

# Uncomment for verbose mode.
#export DH_VERBOSE=1

# Hardening build flags.
export DEB_BUILD_MAINT_OPTIONS=hardening=+all

%:
	dh $@ --with php

override_dh_autoreconf:
	dh_autoreconf ./autogen.sh

override_dh_auto_test:
	REPORT_EXIT_STATUS=1 NO_INTERACTION=1 TESTS="-q --show-diff" dh_auto_test \
	    || echo "Ignoring test failures"

override_dh_auto_install:
	# phpize uses INSTALL_ROOT instead of DESTDIR.
	$(MAKE) install INSTALL_ROOT=$(CURDIR)/debian/php-sfcgal

# When building before libsfcgal2 is installed system-wide (e.g. from a fresh
# extracted .deb), dh_shlibdeps cannot resolve libSFCGAL.so.2 to a package.
# Skip the missing-info bail-out; the explicit Depends: libsfcgal2 (>= 2.2.0)
# in debian/control covers the actual runtime requirement.
override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params=--ignore-missing-info
